                                                    <td class="text-[#f5222d] font-bold">105</td>
                                                    <td class="text-[#f5222d] font-bold">105</td>
                                                    <td class="text-[#f5222d] font-bold">105</td>
                                                    <td class="text-[#f5222d] font-bold">109</td>
                                                    <td class="text-right font-bold text-[#f5222d]">1,154</td>
                                                </tr>

                                                <!-- 经营毛利预测 -->
                                                <tr>
                                                    <td class="py-4 text-left">
                                                        <div class="flex items-center gap-2">
                                                            <div class="w-1.5 h-6 bg-[#f6ffed] rounded-full"></div>
                                                            <div
                                                                class="w-6 h-6 rounded-md bg-[#f6ffed] text-[#52c41a] flex items-center justify-center">
                                                                <i class="fa-solid fa-sack-dollar text-[10px]"></i>
                                                            </div>
                                                            <div>
                                                                <div class="text-[12px] text-gray-700 font-bold">经营毛利预测
                                                                </div>
                                                                <div class="text-[10px] text-gray-400 font-normal">算数差值
                                                                    / 利润</div>
                                                            </div>
                                                        </div>
                                                    </td>
                                                    <td>30</td>
                                                    <td>80</td>
                                                    <td>90</td>
                                                    <td class="text-[#52c41a] font-bold">110</td>
                                                    <td class="text-[#52c41a] font-bold">110</td>
                                                    <td class="text-[#52c41a] font-bold">140</td>
                                                    <td class="text-[#52c41a] font-bold">60</td>
                                                    <td class="text-[#52c41a] font-bold">35</td>
                                                    <td class="text-[#52c41a] font-bold">75</td>
                                                    <td class="text-[#52c41a] font-bold">90</td>
                                                    <td class="text-[#52c41a] font-bold">30</td>
                                                    <td class="text-[#52c41a] font-bold">30</td>
                                                    <td class="text-right font-bold text-[#52c41a]">880</td>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </div>

                                    <!-- Bottom Status Bar -->
                                    <div class="mt-4 pt-4 border-t border-gray-100 flex items-center justify-between">
                                        <div class="flex items-center gap-6">
                                            <div class="flex items-center gap-2">
                                                <div class="w-2 h-2 rounded-full bg-[#52c41a]"></div>
                                                <span class="text-[12px] text-gray-600 font-medium">年度预测对标率: <span
                                                        class="text-gray-800">94.2%</span></span>
                                            </div>
                                            <div class="flex items-center gap-2">
                                                <div class="w-2 h-2 rounded-full bg-[#2f54eb]"></div>
                                                <span class="text-[12px] text-gray-600 font-medium">子项金额覆盖量: <span
                                                        class="text-[#2f54eb]">50%</span></span>
                                            </div>
                                        </div>
                                        <div
                                            class="bg-[#fffbe6] border border-[#ffe58f] text-[#faad14] text-[11px] px-3 py-1.5 rounded-md flex items-center gap-1.5 shadow-sm">
                                            <i class="fa-solid fa-circle-exclamation"></i>
                                            <span>经营效益警示: 当前经营预算与销售端口径存在 450w 差额需补齐</span>
                                        </div>
                                    </div>
                                </div>

                                <!-- 5.5 Dual-Column Config Cards -->
                                <div class="grid grid-cols-2 gap-5 mb-5">
                                    <!-- Left: 经营性质与滚动分类 -->
                                    <div
                                        class="bg-white rounded-2xl p-6 shadow-sm border border-gray-50 flex flex-col h-full">
                                        <div class="flex items-center gap-2 mb-6 text-gray-800 font-bold text-[14px]">
                                            <i class="fa-solid fa-shapes text-[#2f54eb]"></i> 经营性质与滚动分类
                                        </div>

                                        <div class="grid grid-cols-2 gap-4 mb-4">
                                            <div>
                                                <label class="block text-[11px] text-gray-500 mb-1.5">项目分类</label>
                                                <div class="relative">
                                                    <select
                                                        class="w-full border border-gray-200 rounded-lg px-3 py-2.5 text-[13px] text-gray-700 appearance-none bg-white focus:outline-none focus:border-[#2f54eb] focus:ring-1 focus:ring-[#f0f5ff]">
                                                        <option>产品能力</option>
                                                    </select>
                                                    <i
                                                        class="fa-solid fa-angle-down absolute right-3 top-3.5 text-gray-400 text-[10px] pointer-events-none"></i>
                                                </div>
                                            </div>
                                            <div>
                                                <label class="block text-[11px] text-gray-500 mb-1.5">项目类型</label>
                                                <div class="relative">
                                                    <select
                                                        class="w-full border border-gray-200 rounded-lg px-3 py-2.5 text-[13px] text-gray-700 appearance-none bg-white focus:outline-none focus:border-[#2f54eb] focus:ring-1 focus:ring-[#f0f5ff]">
                                                        <option>项目型</option>
                                                    </select>
                                                    <i
                                                        class="fa-solid fa-angle-down absolute right-3 top-3.5 text-gray-400 text-[10px] pointer-events-none"></i>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="mb-4">
                                            <label class="block text-[11px] text-gray-500 mb-1.5">项目滚动线索</label>
                                            <div class="relative">
                                                <select
                                                    class="w-full border border-gray-200 rounded-lg px-3 py-2.5 text-[13px] text-gray-700 appearance-none bg-white focus:outline-none focus:border-[#2f54eb] focus:ring-1 focus:ring-[#f0f5ff]">
                                                    <option>延续项目</option>
                                                </select>
                                                <i
                                                    class="fa-solid fa-angle-down absolute right-3 top-3.5 text-gray-400 text-[10px] pointer-events-none"></i>
                                            </div>
                                        </div>

                                        <div class="text-[11px] text-gray-400 mt-auto pt-2">
                                            提示：延期项目在测算时将直接产生收入的延续单元。
                                        </div>
                                    </div>

                                    <!-- Right: 细分产品画像 -->
                                    <div
                                        class="bg-white rounded-2xl p-6 shadow-sm border border-gray-50 flex flex-col h-full">
                                        <div class="flex items-center gap-2 mb-6 text-gray-800 font-bold text-[14px]">
                                            <i class="fa-solid fa-border-all text-[#52c41a]"></i> 细分产品画像
                                        </div>

                                        <div class="space-y-4">
                                            <div>
                                                <label class="block text-[11px] text-gray-500 mb-1.5">业务营销领域</label>
                                                <div class="relative">
                                                    <select
                                                        class="w-full border border-gray-200 rounded-lg px-3 py-2.5 text-[13px] text-gray-700 appearance-none bg-white focus:outline-none focus:border-[#2f54eb] focus:ring-1 focus:ring-[#f0f5ff]">
                                                        <option>系统集成</option>
                                                    </select>
                                                    <i
                                                        class="fa-solid fa-angle-down absolute right-3 top-3.5 text-gray-400 text-[10px] pointer-events-none"></i>
                                                </div>
                                            </div>

                                            <div>
                                                <label class="block text-[11px] text-gray-500 mb-1.5">产品大类</label>
                                                <div class="relative">
                                                    <select
                                                        class="w-full border border-gray-200 rounded-lg px-3 py-2.5 text-[13px] text-gray-700 appearance-none bg-white pl-3 w-[60%] focus:outline-none focus:border-[#2f54eb] focus:ring-1 focus:ring-[#f0f5ff]">
                                                        <option>产研探索</option>
                                                    </select>
                                                    <i
                                                        class="fa-solid fa-angle-down absolute right-[45%] top-3.5 text-gray-400 text-[10px] pointer-events-none"></i>
                                                </div>
                                            </div>

                                            <div class="pb-2">
                                                <label class="block text-[11px] text-gray-500 mb-1.5">产品细类</label>
                                                <div class="relative">
                                                    <select
                                                        class="w-full border border-gray-200 rounded-lg px-3 py-2.5 text-[13px] text-gray-700 appearance-none bg-white focus:outline-none focus:border-[#2f54eb] focus:ring-1 focus:ring-[#f0f5ff]">
                                                        <option>数字化底座</option>
                                                    </select>
                                                    <i
                                                        class="fa-solid fa-angle-down absolute right-3 top-3.5 text-gray-400 text-[10px] pointer-events-none"></i>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- 5.6 人力资源与采购全周期管控 -->
                                <div
                                    class="bg-white rounded-2xl p-6 shadow-sm border border-gray-50 flex flex-col mb-2">
                                    <div class="flex items-center gap-2 mb-6 text-gray-800 font-bold text-[14px]">
                                        <i class="fa-solid fa-users-gear text-[#1677ff]"></i> 人力资源与采购全周期管控
                                    </div>

                                    <div class="grid grid-cols-2 gap-y-5 gap-x-8">
                                        <!-- Field 1 -->
                                        <div>
                                            <label class="block text-[11px] text-gray-500 mb-1.5">采购总金额 (万元，不含税)</label>
                                            <input type="text" value="450.00"
                                                class="w-full border border-gray-200 rounded-lg px-3 py-2 text-[13px] text-gray-800 bg-[#fafafa] focus:bg-white outline-none focus:border-[#2f54eb] focus:ring-1 focus:ring-[#f0f5ff]">
                                        </div>

                                        <!-- Field 2 -->
                                        <div>
                                            <label class="block text-[11px] text-gray-500 mb-1.5">其中人力采购供应商</label>
                                            <input type="text" value="华为技术有限公司"
                                                class="w-full border border-gray-200 rounded-lg px-3 py-2 text-[13px] text-gray-800 bg-[#fafafa] focus:bg-white outline-none focus:border-[#2f54eb] focus:ring-1 focus:ring-[#f0f5ff]">
                                        </div>

                                        <!-- Field 3 -->
                                        <div>
                                            <label class="block text-[11px] text-gray-500 mb-1.5">其中人力采购金额
                                                (万元，不含税)</label>
                                            <input type="text" value="120.00"
                                                class="w-full border border-gray-200 rounded-lg px-3 py-2 text-[13px] text-gray-800 bg-[#fafafa] focus:bg-white outline-none focus:border-[#2f54eb] focus:ring-1 focus:ring-[#f0f5ff]">
                                        </div>

                                        <!-- Field 4 (Dropdown & Date next to each other in design? No, they are separated. Let's trace the layout: 2 cols. Row 1: Amount, Supplier. Row 2: HR Amount, [Dropdown + Date in two cols? No, the screenshot has 4 fields visible, oh wait it has 5. Let's look closely at the screenshot.
                            Left column: 采购总金额, 其中人力采购金额.
                            Right column: 其中人力采购供应商, 是否已采购, 计划采购时间.
                            Let's adjust to match exact layout.]
                            -->
                                    </div>

                                    <!-- Actually, the screenshot has:
                        Row 1: 采购总金额 (Left), 其中人力采购供应商 (Right)
                        Row 2: 其中人力采购金额 (Left), 然后右边是一排两个: 是否已采购, 计划采购时间
                        -->
                                    <div class="grid grid-cols-2 gap-y-5 gap-x-8 mt-5">
                                        <div class="grid grid-cols-2 gap-x-8 col-start-2">
                                            <div>
                                                <label class="block text-[11px] text-gray-500 mb-1.5">是否已采购</label>
                                                <div class="relative">
                                                    <select
                                                        class="w-full border border-gray-200 rounded-lg px-3 py-2 text-[13px] text-gray-800 appearance-none bg-white focus:outline-none focus:border-[#2f54eb] focus:ring-1 focus:ring-[#f0f5ff]">
                                                        <option>是</option>
                                                    </select>
                                                    <i
                                                        class="fa-solid fa-angle-down absolute right-3 top-3 text-gray-400 text-[10px] pointer-events-none"></i>
                                                </div>
                                            </div>
                                            <div class="relative">
                                                <label class="block text-[11px] text-gray-500 mb-1.5">计划采购时间</label>
                                                <div class="relative">
                                                    <input type="text" value="2026/06/15"
                                                        class="w-full border border-gray-200 rounded-lg px-3 py-2 text-[13px] text-gray-800 bg-white outline-none focus:border-[#2f54eb] focus:ring-1 focus:ring-[#f0f5ff]">
                                                    <i
                                                        class="fa-regular fa-calendar absolute right-3 top-2.5 text-gray-400 text-[12px] pointer-events-none"></i>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                            </div>

                        </div>
                    </div>

                </div>

            </main>
        </div>
    </div>

</body>

</html>